default_platform(:ios)

platform :ios do
  desc "Build the App Store archive, upload it, submit it for review and publish it"
  lane :release do
    key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8"),
      in_house: false
    )

    # xcodebuild wants the key as a file and its identifiers as flags. `build_app` takes no
    # `api_key` of its own — that belongs to `deliver` — so the credentials reach the archive
    # through xcargs. Written under build/, which git ignores and CI throws away.
    key_path = File.expand_path("../build/asc-key.p8", __dir__)
    FileUtils.mkdir_p(File.dirname(key_path))
    File.write(key_path, ENV.fetch("ASC_KEY_P8"))

    # Cloud signing: Xcode fetches the distribution certificate and profile itself, so no
    # .p12 has to be stored anywhere. Needed by both xcodebuild invocations below.
    signing_args = "-allowProvisioningUpdates " \
                   "-authenticationKeyPath #{key_path} " \
                   "-authenticationKeyID #{ENV.fetch('ASC_KEY_ID')} " \
                   "-authenticationKeyIssuerID #{ENV.fetch('ASC_ISSUER_ID')}"

    build_app(
      project: "ios/Shuhari.xcodeproj",
      scheme: "Shuhari",
      configuration: "Release",
      export_method: "app-store",
      # The build number comes from the workflow run, which only ever grows — App Store
      # Connect rejects a number it has already seen.
      xcargs: "#{signing_args} CURRENT_PROJECT_VERSION=#{ENV.fetch('BUILD_NUMBER')}",
      # `gym` runs -exportArchive as a separate xcodebuild invocation, which inherits
      # nothing from `xcargs`. Without the credentials repeated here, the export asks the
      # cloud for a distribution certificate it has no permission to request, and fails on
      # an archive that signed perfectly a minute earlier.
      export_xcargs: signing_args,
      output_directory: "build",
      output_name: "Shuhari.ipa"
    )

    deliver(api_key: key, ipa: "build/Shuhari.ipa")
  end
end
