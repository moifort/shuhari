NITRO_GOOGLE_API_KEY=...
NITRO_ADMIN_TOKEN=your-admin-token
NITRO_SENTRY_DSN=
# Firebase uids comped Premium without paying, comma-separated (the maker's own
# account, a reviewer's). An override on top of real App Store entitlements.
NITRO_PREMIUM_USER_IDS=
# The app's numeric App Store id, needed to verify a Production signature.
NITRO_APPLE_APP_ID=
# Pins App Store signature checks to one environment. Blank tries Production then
# Sandbox (what a shipped app needs); set to Xcode for the local StoreKit file.
NITRO_APPLE_ENVIRONMENT=
# Dev only: userId injected for the local /graphql explorer (defaults to "dev-user")
NITRO_DEV_USER_ID=
