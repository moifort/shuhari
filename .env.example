NITRO_GOOGLE_API_KEY=...
NITRO_ADMIN_TOKEN=your-admin-token
NITRO_SENTRY_DSN=
# Firebase uids on the Premium plan, comma-separated — temporary stand-in for the
# App Store entitlement (see QuotaQuery.planOf). Blank means everyone is Free.
NITRO_PREMIUM_USER_IDS=
# Dev only: userId injected for the local /graphql explorer (defaults to "dev-user")
NITRO_DEV_USER_ID=
